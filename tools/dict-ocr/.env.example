# Copy this file to .env and fill in real values.
# Source of truth for the API key: /Users/pavelbrick/Projects/07_Vibe/vibe-kp/.env
#   GEMINI_API_KEY  -> paste the same value here
#   GEMINI_MODEL    -> paste the same value into LLM_MODEL here
# DO NOT COMMIT THE REAL .env. It is in .gitignore.

GEMINI_API_KEY=your-gemini-api-key-here

# Same model as vibe-kp (gemini-3-flash-preview). Override to gemini-2.5-pro for comparison.
LLM_MODEL=gemini-3-flash-preview

# Rendering controls (match vibe-kp defaults):
#   PDF_ZOOM_LEVEL  - zoom multiplier when rendering PDF page to PNG (default 2.0)
#   PDF_MAX_IMAGE_SIZE - max pixel dimension after rendering (default 2048)
PDF_ZOOM_LEVEL=2.0
PDF_MAX_IMAGE_SIZE=2048

# If set to "true", skips PNG render and sends the PDF page natively (vibe-kp does this for <50MB).
GEMINI_USE_NATIVE_PDF=false

# Retry / timeout
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_MS=120000
